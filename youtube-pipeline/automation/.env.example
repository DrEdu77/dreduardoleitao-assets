# ============================================================
# YouTube Faceless Pipeline — API Keys
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env no GitHub
# ============================================================

# Anthropic (Claude) — platform.anthropic.com/api-keys
ANTHROPIC_API_KEY=sk-ant-...

# ElevenLabs — elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sk_...
# Voice ID da voz clonada Dr. Eduardo (inglês)
ELEVENLABS_VOICE_ID=...

# Pexels — pexels.com/api (gratuito)
PEXELS_API_KEY=...

# YouTube Data API v3 — console.cloud.google.com
# Após criar credenciais OAuth2, baixar client_secrets.json
# O token é gerado automaticamente no primeiro run
YOUTUBE_CLIENT_SECRETS=client_secrets.json
